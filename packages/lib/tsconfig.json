{
	"compilerOptions": {
		"target": "ES2020",
		"useDefineForClassFields": true,
		"module": "ES2020",
		"lib": ["ES2020", "DOM"],
		"moduleResolution": "bundler",
		"strict": true,
		"resolveJsonModule": true,
		"esModuleInterop": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"noImplicitReturns": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"types": ["vite/client"],
		"noEmit": true,
		"declaration": false
	},
	"include": ["src/**/*.ts"],
	"exclude": ["src/**/back/**"]
}
